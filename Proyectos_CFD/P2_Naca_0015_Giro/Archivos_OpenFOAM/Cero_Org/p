FoamFile
{
    format      ascii;
    class       volScalarField;
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    inlet_extruded
    {
        type            freestreamPressure;
        freestreamValue $internalField;
    }

    outlet_extruded
    {
        type            freestreamPressure;
        freestreamValue $internalField;
    }

    walls_extruded
    {
        type            zeroGradient;
    }
    
    curve_extruded
    {
        type            zeroGradient;
    }  

    frontAndBack
    {
        type            empty;
    }
    
    frontAndBack_top
    {
        type            empty;
    }
    
      
}

